# Env shape for docker-compose.actions-runner.yml.
# Copy this file or set these variables in Coolify's environment-variables UI.

# Required: classic PAT on a user account with admin:org scope on the retainer org.
# Mint at https://github.com/settings/tokens/new — name it
# "<retainer>-coolify-actions-runner", scope `admin:org`, 1y expiry.
ACCESS_TOKEN=ghp_replace_with_admin_org_pat

# Required: retainer org name (case-sensitive, matches the GitHub URL slug).
RUNNER_OWNER=Haverford-Brands

# Optional. Defaults to self-hosted,linux,retainer if unset. Add a retainer-
# specific label so pipeline-core workflows can target the right pool later if
# multiple retainers are running pools on shared infra.
RUNNER_LABELS=self-hosted,linux,retainer,haverford
